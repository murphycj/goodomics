FROM node:24-slim AS dashboard

WORKDIR /app/packages/goodomics-server/dashboard
COPY packages/goodomics-server/dashboard/package*.json ./
RUN npm ci
COPY packages/goodomics-server/dashboard/ ./
RUN npm run build

FROM python:3.11-slim AS server

WORKDIR /app

COPY . /app
COPY --from=dashboard /app/packages/goodomics-server/src/goodomics_server/web/static \
  /app/packages/goodomics-server/src/goodomics_server/web/static

RUN pip install uv && uv sync --all-packages --package goodomics-server

EXPOSE 8000

CMD ["uv", "run", "--package", "goodomics-server", "goodomics-server", "serve", "--host", "0.0.0.0", "--port", "8000"]
